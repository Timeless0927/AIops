EXPOSE 8084
HEALTHCHECK --interval=10s --timeout=3s --retries=6 \
    CMD curl -fsS "http://127.0.0.1:${AIOPS_LOKI_MCP_PORT}/healthz" >/dev/null || exit 1

ENTRYPOINT ["/app/deploy/entrypoint-mcp-loki.sh"]

FROM base AS hermes-smoke

RUN mkdir -p /app/apps /app/deploy /app/runtime
COPY apps/__init__.py apps/service_http.py /app/apps/
COPY hermes /app/hermes
COPY aiops /app/aiops
COPY toolsets/__init__.py toolsets/incident_store.py toolsets/incident_diagnosis.py /app/toolsets/
COPY runtime/__init__.py runtime/service_image_smoke.py runtime/service_mesh_smoke.py /app/runtime/
COPY deploy/entrypoint-hermes.sh /app/deploy/entrypoint-hermes.sh
RUN chmod +x /app/deploy/entrypoint-hermes.sh

ENV AIOPS_HERMES_HOST=0.0.0.0 \
    AIOPS_HERMES_PORT=8082 \
    AIOPS_GATEWAY_URL=http://gateway:8080

EXPOSE 8082
HEALTHCHECK --interval=10s --timeout=3s --retries=6 \
    CMD curl -fsS "http://127.0.0.1:${AIOPS_HERMES_PORT}/healthz" >/dev/null || exit 1

ENTRYPOINT ["/app/deploy/entrypoint-hermes.sh"]

FROM hermes-runtime AS aiops

RUN mkdir -p /app/deploy
COPY aiops /app/aiops
COPY apps /app/apps
COPY hermes /app/hermes
COPY hooks /app/hooks
COPY runtime /app/runtime
COPY skills /app/skills
COPY toolsets /app/toolsets
COPY deploy/entrypoint.sh deploy/hermes-config.template.yaml /app/deploy/
RUN chmod +x /app/deploy/entrypoint.sh

VOLUME ["/data"]

ENTRYPOINT ["/app/deploy/entrypoint.sh"]
