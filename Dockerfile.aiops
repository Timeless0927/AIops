COPY apps/__init__.py apps/service_http.py apps/observability_http.py /app/apps/
COPY apps/mcp_prometheus /app/apps/mcp_prometheus
COPY aiops /app/aiops
COPY toolsets/__init__.py toolsets/query_guard.py toolsets/audit_log.py toolsets/prometheus_query.py /app/toolsets/
COPY runtime/__init__.py runtime/service_image_smoke.py /app/runtime/
COPY deploy/entrypoint-mcp-prometheus.sh /app/deploy/entrypoint-mcp-prometheus.sh
RUN chmod +x /app/deploy/entrypoint-mcp-prometheus.sh

ENV AIOPS_PROMETHEUS_MCP_HOST=0.0.0.0 \
    AIOPS_PROMETHEUS_MCP_PORT=8083

EXPOSE 8083
HEALTHCHECK --interval=10s --timeout=3s --retries=6 \
    CMD curl -fsS "http://127.0.0.1:${AIOPS_PROMETHEUS_MCP_PORT}/healthz" >/dev/null || exit 1

ENTRYPOINT ["/app/deploy/entrypoint-mcp-prometheus.sh"]

FROM base AS mcp-loki

RUN mkdir -p /app/apps /app/deploy /app/runtime /app/toolsets
COPY apps/__init__.py apps/service_http.py apps/observability_http.py /app/apps/
COPY apps/mcp_loki /app/apps/mcp_loki
COPY aiops /app/aiops
COPY toolsets/__init__.py toolsets/query_guard.py toolsets/audit_log.py toolsets/loki_query.py /app/toolsets/
COPY runtime/__init__.py runtime/service_image_smoke.py runtime/image_smoke.py /app/runtime/
COPY deploy/entrypoint-mcp-loki.sh /app/deploy/entrypoint-mcp-loki.sh
RUN chmod +x /app/deploy/entrypoint-mcp-loki.sh

ENV AIOPS_LOKI_MCP_HOST=0.0.0.0 \
